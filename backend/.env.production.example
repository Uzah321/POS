# ============================================================
# NEXAPOS — PRODUCTION ENVIRONMENT TEMPLATE
# Copy to .env and fill in all values before deploying.
# ============================================================

APP_NAME="NexaPOS"
APP_ENV=production
APP_KEY=                          # Run: php artisan key:generate
APP_DEBUG=false
APP_URL=https://your-domain.com   # e.g. https://pos.diapermart.co.zw

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

# ── Logging ──────────────────────────────────────────────────
LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=error                   # Only log errors in production

# ── Database (PostgreSQL) ────────────────────────────────────
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1                 # or your DB server IP
DB_PORT=5432
DB_DATABASE=nexapos_prod
DB_USERNAME=nexapos_user
DB_PASSWORD=STRONG_PASSWORD_HERE

# ── Session & Cache ──────────────────────────────────────────
SESSION_DRIVER=database
SESSION_LIFETIME=480              # 8 hours
SESSION_ENCRYPT=true
SESSION_SECURE_COOKIE=true        # Requires HTTPS
SESSION_DOMAIN=your-domain.com

CACHE_STORE=database

# ── Queue ────────────────────────────────────────────────────
# Use 'database' (simple) or 'redis' (recommended for production)
QUEUE_CONNECTION=database

# ── Redis (optional — improves performance) ──────────────────
# REDIS_CLIENT=phpredis
# REDIS_HOST=127.0.0.1
# REDIS_PASSWORD=null
# REDIS_PORT=6379
# CACHE_STORE=redis
# QUEUE_CONNECTION=redis
# SESSION_DRIVER=redis

# ── Mail ─────────────────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_HOST=smtp.mailgun.org        # or SendGrid, SES, etc.
MAIL_PORT=587
MAIL_USERNAME=your@email.com
MAIL_PASSWORD=your_mail_password
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@your-domain.com
MAIL_FROM_NAME="NexaPOS"

# ── CORS ─────────────────────────────────────────────────────
# Set to your frontend domain (no trailing slash)
FRONTEND_URL=https://your-domain.com

# ── Filesystem ───────────────────────────────────────────────
FILESYSTEM_DISK=local

VITE_APP_NAME="NexaPOS"
