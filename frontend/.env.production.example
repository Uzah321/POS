# Frontend production environment
# Copy to .env.production and set values before running: npm run build

# If backend is on a different domain/subdomain, set the full API URL:
VITE_API_URL=https://api.your-domain.com/api

# If backend is served from the same domain under /api, leave blank (uses proxy/relative path):
# VITE_API_URL=

VITE_APP_NAME=NexaPOS
